# =====================
# App
# =====================
PROJECT_NAME=Dongle Project
SECRET_KEY=change-me-to-random-string
ENV=develop
ADMIN_SECRET_KEY=change-me-to-random-string

# =====================
# DB
# =====================
DATABASE_URL="postgresql+asyncpg://USER:PASSWORD@127.0.0.1:5432/DBNAME"

# =====================
# JWT
# =====================
JWT_SECRET=change-me-to-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_TOKEN_URL="/api/v1/auth/jwt/login"

# =====================
# Debug
# =====================
DEBUG=True
TESTING=False

# =====================
# Logging
# =====================
LOG_DIR=./logs
LOG_LEVEL=INFO

# =====================
# CORS (콤마 구분 또는 JSON 배열)
# =====================
CORS_ORIGINS=http://localhost:3031,http://127.0.0.1:3031

# =====================
# ClickHouse (옵셔널 — 사용하지 않으면 비워둬도 됨)
# =====================
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=
CH_DB=default
